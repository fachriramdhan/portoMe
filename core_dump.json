{"app.ts":"import { ChangeDetectionStrategy, Component, signal, computed, HostListener, PLATFORM_ID, AfterViewInit, ElementRef, ViewChild, inject } from '@angular/core';\nimport { isPlatformBrowser } from '@angular/common';\nimport { LanguageService } from './services/language.service';\nimport { AboutComponent } from './components/about';\nimport { SkillsComponent } from './components/skills';\nimport { ProjectsComponent } from './components/projects';\nimport { ExperienceComponent } from './components/experience';\nimport { ContactComponent } from './components/contact';\nimport { CustomCursorComponent } from './components/custom-cursor';\nimport { GithubActivityComponent } from './components/github-activity';\nimport { EducationComponent } from './components/education';\nimport { CertificatesComponent } from './components/certificates';\nimport { MatIconModule } from '@angular/material/icon';\n\n@Component({\n  selector: 'app-root',\n  changeDetection: ChangeDetectionStrategy.OnPush,\n  imports: [\n    AboutComponent,\n    SkillsComponent,\n    ProjectsComponent,\n    ExperienceComponent,\n    ContactComponent,\n    CustomCursorComponent,\n    GithubActivityComponent,\n    EducationComponent,\n    CertificatesComponent,\n    MatIconModule\n  ],\n  template: `\n    <app-custom-cursor />\n    <div class=\"relative min-h-screen w-full bg-gray-50 dark:bg-[#050505] text-gray-900 dark:text-white selection:bg-[#b026ff]/30 selection:text-gray-900 dark:selection:text-white flex flex-col lg:flex-row font-sans lg:overflow-hidden transition-colors duration-500\">\n      <!-- Performant Tech Grid Background -->\n      <div class=\"fixed inset-0 z-0 pointer-events-none\">\n        <div class=\"absolute inset-0 bg-[linear-gradient(to_right,#0000000a_1px,transparent_1px),linear-gradient(to_bottom,#0000000a_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:32px_32px] transition-colors duration-500\"></div>\n        <div class=\"absolute left-[-10%] top-[-10%] -z-10 h-[60%] w-[60%] rounded-full bg-gradient-to-br from-[#b026ff] to-transparent opacity-10 dark:opacity-20 blur-[120px] transition-opacity duration-500 animate-pulse\" style=\"animation-duration: 8s;\"></div>\n        <div class=\"absolute right-[-10%] bottom-[-10%] -z-10 h-[60%] w-[60%] rounded-full bg-gradient-to-tl from-[#00f0ff] to-transparent opacity-10 dark:opacity-20 blur-[120px] transition-opacity duration-500 animate-pulse\" style=\"animation-duration: 10s; animation-delay: 2s;\"></div>\n      </div>\n\n      <!-- Left Sidebar (Fixed on Desktop, Normal on Mobile) -->\n      <header class=\"lg:sticky lg:top-0 lg:flex lg:h-screen lg:w-[45%] xl:w-[40%] lg:flex-col lg:justify-between lg:py-16 lg:pl-24 lg:pr-16 pt-32 pb-12 px-6 sm:px-8 z-10 lg:overflow-hidden no-scrollbar\">\n        <div>\n          <h1 class=\"text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-display font-black tracking-tighter mb-2 lg:mb-4 text-transparent bg-clip-text bg-gradient-to-br from-gray-900 via-gray-800 to-gray-500 dark:from-white dark:via-gray-200 dark:to-gray-500 leading-tight py-2\">\n            Fachri\n          </h1>\n          <h2 class=\"text-base sm:text-lg lg:text-xl xl:text-2xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-[#b026ff] to-[#00f0ff] mb-4 lg:mb-6 tracking-wide\">\n            {{ lang() === 'id' ? 'Software Engineering' : 'Software Engineering' }}\n          </h2>\n          <p class=\"text-gray-600 dark:text-gray-400 max-w-md leading-relaxed font-light text-sm sm:text-base lg:text-base xl:text-lg transition-colors duration-500 mb-5\">\n            {{ lang() === 'id' ? 'Saya membangun aplikasi web premium dan mengintegrasikannya secara mulus dengan otomasi industri. Perangkat lunak berkinerja tinggi bertemu dengan sistem pabrik yang tangguh.' : 'I build premium web applications and integrate them seamlessly with industrial automation. High-performance software meets robust factory systems.' }}\n          </p>\n\n          <!-- Availability Badges -->\n          <div class=\"flex flex-wrap gap-2 mb-6 lg:mb-8 max-w-md\">\n            <span class=\"px-3 py-1.5 text-[10px] sm:text-xs font-medium rounded-full bg-green-100 text-green-700 dark:bg-green-500/10 dark:text-green-400 border border-green-200 dark:border-green-500/20 flex items-center gap-1.5 w-max\">\n              <span class=\"relative flex h-2 w-2\">\n                <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75\"></span>\n                <span class=\"relative inline-flex rounded-full h-2 w-2 bg-green-500\"></span>\n              </span>\n              Open to Work\n            </span>\n            <span class=\"px-3 py-1.5 text-[10px] sm:text-xs font-medium rounded-full bg-blue-100 text-blue-700 dark:bg-blue-500/10 dark:text-blue-400 border border-blue-200 dark:border-blue-500/20 flex items-center gap-1.5 w-max\">\n              🤝 {{ lang() === 'id' ? 'Kolaborasi' : 'Collaboration' }}\n            </span>\n            <span class=\"px-3 py-1.5 text-[10px] sm:text-xs font-medium rounded-full bg-purple-100 text-purple-700 dark:bg-purple-500/10 dark:text-purple-400 border border-purple-200 dark:border-purple-500/20 flex items-center gap-1.5 w-max\">\n              🚀 {{ lang() === 'id' ? 'Proyek Kustom' : 'Custom Projects' }}\n            </span>\n          </div>\n\n          <!-- Download CV Button -->\n          <a href=\"/assets/cv-fachri.pdf\" download=\"CV_Fachri_SoftwareEngineer.pdf\" class=\"group relative inline-flex items-center justify-center gap-3 px-6 py-3 lg:px-6 lg:py-3 xl:px-8 xl:py-4 rounded-full bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-bold text-xs lg:text-xs xl:text-sm tracking-widest uppercase overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(176,38,255,0.3)] dark:hover:shadow-[0_0_40px_rgba(0,240,255,0.3)] w-max\">\n            <div class=\"absolute inset-0 bg-gradient-to-r from-[#b026ff] to-[#00f0ff] opacity-0 group-hover:opacity-20 transition-opacity duration-300\"></div>\n            <mat-icon class=\"scale-90 transition-transform duration-300 group-hover:-translate-y-1\">download</mat-icon>\n            <span class=\"relative z-10\">{{ lang() === 'id' ? 'Unduh CV' : 'Download CV' }}</span>\n          </a>\n\n        </div>\n\n        <div class=\"mt-8 lg:mt-auto flex items-center gap-4 xl:gap-6\">\n          <a href=\"https://github.com\" target=\"_blank\" title=\"GitHub\" class=\"text-gray-400 dark:text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors hover:scale-110 transform duration-300\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z\"/></svg>\n          </a>\n          <a href=\"https://linkedin.com\" target=\"_blank\" title=\"LinkedIn\" class=\"text-gray-400 dark:text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors hover:scale-110 transform duration-300\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/></svg>\n          </a>\n          <a href=\"mailto:fachrirahman2000@gmail.com\" title=\"Email\" class=\"text-gray-400 dark:text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors hover:scale-110 transform duration-300\">\n            <mat-icon>mail</mat-icon>\n          </a>\n          <!-- Language Toggle (Desktop) -->\n          <button (click)=\"toggleLanguage()\" class=\"hidden lg:flex p-2 rounded-full bg-gray-200/50 dark:bg-white/5 text-gray-600 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-white/10 transition-all duration-300 items-center justify-center hover:scale-110 font-bold text-xs w-10 h-10\" [attr.aria-label]=\"lang() === 'id' ? 'Ganti Bahasa' : 'Toggle Language'\">\n            {{ lang() === 'id' ? 'EN' : 'ID' }}\n          </button>\n          <!-- Theme Toggle (Desktop) -->\n          <button (click)=\"toggleTheme()\" class=\"hidden lg:flex p-3 rounded-full bg-gray-200/50 dark:bg-white/5 text-gray-600 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-white/10 transition-all duration-300 items-center justify-center hover:scale-110\" [attr.aria-label]=\"lang() === 'id' ? 'Ganti Mode Gelap' : 'Toggle Dark Mode'\">\n            <mat-icon class=\"scale-90\">{{ isDarkMode() ? 'light_mode' : 'dark_mode' }}</mat-icon>\n          </button>\n        </div>\n      </header>\n\n      <!-- Mobile Top Bar (Sticky) -->\n      <nav class=\"lg:hidden fixed top-0 left-0 right-0 z-40 bg-white/80 dark:bg-[#050505]/80 backdrop-blur-xl px-4 sm:px-6 py-3 border-b border-gray-200 dark:border-white/10 flex items-center justify-between transition-colors duration-500 shadow-sm\">\n        <span class=\"font-display font-bold text-lg sm:text-xl tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-400\">Fachri</span>\n        <div class=\"flex items-center gap-1 sm:gap-2\">\n          <!-- Quick Links in Top Bar -->\n          <a href=\"#projects\" (click)=\"scrollTo('projects', $event)\" class=\"p-2 rounded-full text-gray-500 dark:text-gray-400 hover:text-[#b026ff] dark:hover:text-[#00f0ff] hover:bg-gray-100 dark:hover:bg-white/10 transition-colors flex items-center justify-center\" [attr.aria-label]=\"lang() === 'id' ? 'Proyek' : 'Projects'\">\n            <mat-icon class=\"scale-90\">work</mat-icon>\n          </a>\n          <a href=\"#contact\" (click)=\"scrollTo('contact', $event)\" class=\"p-2 rounded-full text-gray-500 dark:text-gray-400 hover:text-[#b026ff] dark:hover:text-[#00f0ff] hover:bg-gray-100 dark:hover:bg-white/10 transition-colors flex items-center justify-center\" [attr.aria-label]=\"lang() === 'id' ? 'Kontak' : 'Contact'\">\n            <mat-icon class=\"scale-90\">mail</mat-icon>\n          </a>\n          <div class=\"w-px h-6 bg-gray-200 dark:bg-white/10 mx-1\"></div>\n          <!-- Language Toggle (Mobile) -->\n          <button (click)=\"toggleLanguage()\" class=\"p-2 rounded-full text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors flex items-center justify-center font-bold text-xs w-9 h-9\" [attr.aria-label]=\"lang() === 'id' ? 'Ganti Bahasa' : 'Toggle Language'\">\n            {{ lang() === 'id' ? 'EN' : 'ID' }}\n          </button>\n          <!-- Theme Toggle (Mobile) -->\n          <button (click)=\"toggleTheme()\" class=\"p-2 rounded-full text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors flex items-center justify-center\" [attr.aria-label]=\"lang() === 'id' ? 'Ganti Mode Gelap' : 'Toggle Dark Mode'\">\n            <mat-icon class=\"scale-90\">{{ isDarkMode() ? 'light_mode' : 'dark_mode' }}</mat-icon>\n          </button>\n          <!-- Hamburger Menu Toggle -->\n          <button (click)=\"toggleMobileMenu()\" class=\"p-2 rounded-full text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors flex items-center justify-center\" aria-label=\"Menu\">\n            <mat-icon class=\"scale-90\">menu</mat-icon>\n          </button>\n        </div>\n      </nav>\n\n      <!-- Mobile Hamburger Menu Overlay -->\n      @if (isMobileMenuOpen()) {\n        <div class=\"lg:hidden fixed inset-0 z-50 bg-white/95 dark:bg-[#050505]/95 backdrop-blur-2xl flex flex-col pt-20 px-6 pb-24 transition-colors duration-500 overflow-y-auto\">\n          <button (click)=\"toggleMobileMenu()\" class=\"absolute top-4 right-4 p-2 rounded-full bg-gray-100 dark:bg-white/10 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-white/20 transition-colors\">\n            <mat-icon>close</mat-icon>\n          </button>\n          \n          <h3 class=\"text-[10px] sm:text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-4\">{{ lang() === 'id' ? 'Menu Navigasi' : 'Navigation Menu' }}</h3>\n          <ul class=\"flex flex-col gap-2 mb-8\">\n            @for (link of allLinks(); track link.id) {\n              <li>\n                <a [href]=\"'#' + link.id\" (click)=\"scrollTo(link.id, $event)\" class=\"flex items-center gap-4 p-3 sm:p-4 rounded-2xl transition-all duration-300\" [class.bg-gray-100]=\"activeSection() === link.id\" [class.dark:bg-white/10]=\"activeSection() === link.id\" [class.text-gray-900]=\"activeSection() === link.id\" [class.dark:text-white]=\"activeSection() === link.id\" [class.text-gray-500]=\"activeSection() !== link.id\" [class.dark:text-gray-400]=\"activeSection() !== link.id\">\n                  <mat-icon [class.text-[#b026ff]]=\"activeSection() === link.id\" [class.dark:text-[#00f0ff]]=\"activeSection() === link.id\">{{ link.icon }}</mat-icon>\n                  <span class=\"font-semibold text-base sm:text-lg\">{{ link.name }}</span>\n                </a>\n              </li>\n            }\n          </ul>\n\n          <h3 class=\"text-[10px] sm:text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-4\">{{ lang() === 'id' ? 'Tautan Sosial' : 'Social Links' }}</h3>\n          <div class=\"flex flex-col gap-2\">\n            <a href=\"https://github.com\" target=\"_blank\" class=\"flex items-center gap-4 p-3 sm:p-4 rounded-2xl bg-gray-50 dark:bg-white/5 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z\"/></svg>\n              <span class=\"font-medium text-sm sm:text-base\">GitHub</span>\n            </a>\n            <a href=\"https://linkedin.com\" target=\"_blank\" class=\"flex items-center gap-4 p-3 sm:p-4 rounded-2xl bg-gray-50 dark:bg-white/5 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/></svg>\n              <span class=\"font-medium text-sm sm:text-base\">LinkedIn</span>\n            </a>\n            <a href=\"mailto:fachrirahman2000@gmail.com\" class=\"flex items-center gap-4 p-3 sm:p-4 rounded-2xl bg-gray-50 dark:bg-white/5 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors\">\n              <mat-icon>mail</mat-icon>\n              <span class=\"font-medium text-sm sm:text-base\">Email</span>\n            </a>\n          </div>\n        </div>\n      }\n\n      <!-- Right Content (Scrollable on Desktop, Normal on Mobile) -->\n      <main #scrollContainer class=\"lg:w-[55%] xl:w-[60%] px-6 sm:px-8 pt-28 pb-12 lg:pt-0 lg:pb-24 lg:pr-24 lg:pl-12 lg:overflow-y-auto lg:h-screen no-scrollbar relative z-10 scroll-smooth\" (scroll)=\"onScroll()\">\n        \n        <!-- Desktop Sticky Nav (Topbar) -->\n        <nav class=\"hidden lg:flex sticky top-12 z-50 bg-white/80 dark:bg-[#111]/80 backdrop-blur-xl py-3 px-6 rounded-full border border-gray-200/50 dark:border-white/10 shadow-sm mx-auto w-max mb-16 mt-12\">\n          <ul class=\"flex flex-wrap gap-x-2 xl:gap-x-4 items-center\">\n            @for (link of allLinks(); track link.id) {\n              <li>\n                <a class=\"group relative text-[10px] xl:text-xs font-bold uppercase tracking-widest transition-all duration-300 py-2 px-3 rounded-full\"\n                   [class.text-[#b026ff]]=\"activeSection() === link.id\"\n                   [class.dark:text-[#00f0ff]]=\"activeSection() === link.id\"\n                   [class.bg-gray-100]=\"activeSection() === link.id\"\n                   [class.dark:bg-white/10]=\"activeSection() === link.id\"\n                   [class.text-gray-500]=\"activeSection() !== link.id\"\n                   [class.hover:text-gray-900]=\"activeSection() !== link.id\"\n                   [class.dark:hover:text-white]=\"activeSection() !== link.id\"\n                   [class.hover:bg-gray-50]=\"activeSection() !== link.id\"\n                   [class.dark:hover:bg-white/5]=\"activeSection() !== link.id\"\n                   [href]=\"'#' + link.id\" (click)=\"scrollTo(link.id, $event)\">\n                  {{ link.name }}\n                </a>\n              </li>\n            }\n          </ul>\n        </nav>\n\n        <div class=\"flex flex-col gap-16 lg:gap-28 lg:pt-4\">\n          <app-about id=\"about\" class=\"scroll-mt-28 lg:scroll-mt-32 block\" />\n          <app-github-activity class=\"block\" />\n          <app-skills id=\"skills\" class=\"scroll-mt-28 lg:scroll-mt-32 block\" />\n          <app-projects id=\"projects\" class=\"scroll-mt-28 lg:scroll-mt-32 block\" />\n          <app-experience id=\"experience\" class=\"scroll-mt-28 lg:scroll-mt-32 block\" />\n          <app-education id=\"education\" class=\"scroll-mt-28 lg:scroll-mt-32 block\" />\n          <app-certificates id=\"certificates\" class=\"scroll-mt-28 lg:scroll-mt-32 block\" />\n          <app-contact id=\"contact\" class=\"scroll-mt-28 lg:scroll-mt-32 block\" />\n          \n          <footer class=\"py-8 text-gray-500 text-sm border-t border-gray-200 dark:border-white/5 mt-10 transition-colors duration-500\">\n            <p>© {{ currentYear }} Fachri. {{ lang() === 'id' ? 'Hak cipta dilindungi undang-undang.' : 'All rights reserved.' }}</p>\n            <p class=\"mt-2 text-gray-400 dark:text-gray-500 transition-colors duration-500\">{{ lang() === 'id' ? 'Membangun sistem cerdas antara perangkat lunak dan mesin.' : 'Building intelligent systems between software and machines.' }}</p>\n          </footer>\n        </div>\n      </main>\n    </div>\n  `,\n  styles: []\n})\nexport class App implements AfterViewInit {\n  langService = inject(LanguageService);\n  lang = this.langService.currentLang;\n\n  currentYear = new Date().getFullYear();\n  activeSection = signal<string>('about');\n  isDarkMode = signal<boolean>(true);\n  isMobileMenuOpen = signal<boolean>(false);\n  \n  @ViewChild('scrollContainer') scrollContainer!: ElementRef<HTMLElement>;\n\n  allLinks = computed(() => [\n    { name: this.lang() === 'id' ? 'Tentang' : 'About', id: 'about', icon: 'person' },\n    { name: this.lang() === 'id' ? 'Keahlian' : 'Skills', id: 'skills', icon: 'code' },\n    { name: this.lang() === 'id' ? 'Proyek' : 'Projects', id: 'projects', icon: 'work' },\n    { name: this.lang() === 'id' ? 'Pengalaman' : 'Experience', id: 'experience', icon: 'timeline' },\n    { name: this.lang() === 'id' ? 'Pendidikan' : 'Education', id: 'education', icon: 'school' },\n    { name: this.lang() === 'id' ? 'Sertifikasi' : 'Certifications', id: 'certificates', icon: 'workspace_premium' },\n    { name: this.lang() === 'id' ? 'Kontak' : 'Contact', id: 'contact', icon: 'mail' },\n  ]);\n\n  private platformId = inject(PLATFORM_ID);\n\n  ngAfterViewInit() {\n    if (isPlatformBrowser(this.platformId)) {\n      setTimeout(() => this.onScroll(), 100);\n      \n      // Initialize theme\n      if (this.isDarkMode()) {\n        document.documentElement.classList.add('dark');\n      }\n    }\n  }\n\n  toggleTheme() {\n    this.isDarkMode.update(v => !v);\n    if (isPlatformBrowser(this.platformId)) {\n      if (this.isDarkMode()) {\n        document.documentElement.classList.add('dark');\n      } else {\n        document.documentElement.classList.remove('dark');\n      }\n    }\n  }\n\n  toggleLanguage() {\n    this.langService.toggleLanguage();\n  }\n\n  toggleMobileMenu() {\n    this.isMobileMenuOpen.update(v => !v);\n  }\n\n  scrollTo(id: string, event: Event) {\n    event.preventDefault();\n    this.isMobileMenuOpen.set(false);\n    if (isPlatformBrowser(this.platformId)) {\n      const element = document.getElementById(id);\n      if (element) {\n        element.scrollIntoView({ behavior: 'smooth' });\n        this.activeSection.set(id);\n      }\n    }\n  }\n\n  @HostListener('window:scroll')\n  onWindowScroll() {\n    if (isPlatformBrowser(this.platformId) && window.innerWidth < 1024) {\n      this.checkScrollPosition();\n    }\n  }\n\n  onScroll() {\n    if (!isPlatformBrowser(this.platformId)) return;\n    if (window.innerWidth >= 1024) {\n      this.checkScrollPosition();\n    }\n  }\n\n  private checkScrollPosition() {\n    let current = 'about';\n    for (const link of this.allLinks()) {\n      const element = document.getElementById(link.id);\n      if (element) {\n        const rect = element.getBoundingClientRect();\n        if (rect.top <= window.innerHeight / 2) {\n          current = link.id;\n        }\n      }\n    }\n    \n    if (this.activeSection() !== current) {\n      this.activeSection.set(current);\n    }\n  }\n}\n\n"}